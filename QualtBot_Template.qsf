mbeddedData":[{"Description":"bot_icon","Type":"Custom","Field":"bot_icon","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"\ud83e\udd16"}]},{"Type":"EmbeddedData","FlowID":"FL_8","EmbeddedData":[{"Description":"user_icon","Type":"Custom","Field":"user_icon","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"\ud83e\uddd1\u200d\ud83c\udf93"}]},{"Type":"Block","ID":"BL_3wo5UpF4Spa53vM","FlowID":"FL_2","Autofill":[]},{"Type":"Standard","ID":"BL_bDHcdTkUfzRnF0a","FlowID":"FL_9","Autofill":[]}],"Properties":{"Count":10}}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"62a45261-b9b6-4bab-ae00-433c16c35277"}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"5","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"RS","PrimaryAttribute":"RS_8rciuQoo8hvrQEK","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":"","PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"uclioe","SkinType":"templated","Skin":{"brandingId":"9370853168","templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","CustomStyles":{"customCSS":"body {\n  margin: 0;\n}\n\n\/* 1. The Wrapper controls the size and the centering *\/\n.wrapper {\n  position: relative; \/* This traps the absolute positioned footer inside *\/\n  width: 70vw;        \/* Matches iframe width *\/\n  height: 70vh;       \/* Matches iframe height *\/\n  margin: 0 auto;     \/* Centers the whole block perfectly *\/\n  z-index: 1;\n}\n\n\/* 2. The Iframe fills up 100% of the wrapper *\/\niframe {\n  display: block;\n  width: 100%;\n  height: 100%;\n  border: none;\n  background: #ffffff;\n}\n\n\/* 3. The Footer Blocker perfectly overlaps the bottom of the wrapper *\/\n.hidefooter {\n  position: absolute;\n  bottom: 0;          \/* Sticks it to the very bottom of the wrapper *\/\n  left: 0;            \/* Sticks it to the left edge of the wrapper *\/\n  width: 100%;        \/* Makes it span the exact width of the iframe *\/\n  height: 35px;\n  background: rgb(255,255,255,255);\n  z-index: 2;\n}\n\n\/* 4. Mobile Styles *\/\n@media (max-width: 768px) {\n  .wrapper {\n    width: 90vw;      \/* On mobile, expand the wrapper to 90vw *\/\n    height: 90vh;\n  }\n\n}"}}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;<br>","DefaultChoices":false,"DataExportTag":"chatbot1 ","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID4","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\/\/ EDIT TO CUSTOMISE CHATBOT\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\n\t\/\/ Define the starting message (e.g., Hello, how can i help you today?)\n\tvar myInitialMsg = \"Hello, how can I help you today?\";\n\t\n    \/\/ Define your custom prompt\n    var mySurveyPrompt = `You are a helpful academic assistant`; \n\n\t\/\/ Define the number of conversational turns\n\tvar maxTurns = 2; \/\/ Change this number to your desired limit\n\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\/\/ DON'T EDIT ANYTHING FROM HERE\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\n\tvar qthis = this;\n    \n    \/\/ Hide ONLY this question's text box. The text box (multiline) is used to save the chat, but we must make it hidden. This targets the textarea specifically within this question's container\n    var inputField = this.getQuestionContainer().querySelector('textarea');\n    if (inputField) {\n        inputField.style.display = 'none';\n    }\n\t\n\t\/\/ To edit the provider, model, and app url, configure myProvider, myModel, and appURL as Embedded variables within survey flow. Make sure these appear at the very top of the survey flow.  \n    var myProvider = Qualtrics.SurveyEngine.getEmbeddedData('myProvider');\n    var myModel = Qualtrics.SurveyEngine.getEmbeddedData('myModel');\n\tvar baseUrl = Qualtrics.SurveyEngine.getEmbeddedData('appURL');\t\n\n\tvar userIcon = Qualtrics.SurveyEngine.getEmbeddedData('user_icon');\n\tvar botIcon = Qualtrics.SurveyEngine.getEmbeddedData('bot_icon');\t\n\t\n    \/\/ Custom Colors (Use Hex codes)\n    var bgColour = Qualtrics.SurveyEngine.getEmbeddedData('bgColour');\t; \/\/ Changes the main app background\n    var userColour = Qualtrics.SurveyEngine.getEmbeddedData('userColour'); \/\/ Changes the user's chat bubble and accents\n    var botColour = Qualtrics.SurveyEngine.getEmbeddedData('botColour');; \/\/ Changes the bot's chat bubble and input box\n    var textColour = Qualtrics.SurveyEngine.getEmbeddedData('textColour'); \/\/ Changes the main text color\n\n    \/\/ Encode the colors so the '#' symbol does not break the URL\n    var safebgColour = encodeURIComponent(bgColour);\n\tvar safeuserColour = encodeURIComponent(userColour);\n    var safebotColour = encodeURIComponent(botColour);\n    var safetextColour = encodeURIComponent(textColour);\t\n\t\n\t\/\/ Encode the variables so the ' ' do not break the URL\n\tvar safePrompt = encodeURIComponent(mySurveyPrompt);\n\tvar safeInitialMsg = encodeURIComponent(myInitialMsg);\n\tvar safeUserIcon  = encodeURIComponent(userIcon);\n\tvar safeBotIcon = encodeURIComponent(botIcon);\n\t\n\t\/\/ Build the final URL with all the URL variables\n    var finalUrl = baseUrl + \"?embed=true\" \n        + \"&prompt=\" + safePrompt \n        + \"&provider=\" + myProvider \n        + \"&model=\" + myModel \n        + \"&initial_msg=\" + safeInitialMsg \n        + \"&max_turns=\" + maxTurns \n        + \"&user_icon=\" + safeUserIcon \n        + \"&bot_icon=\" + safeBotIcon\n        + \"&theme.primaryColor=\" + safeuserColour\n        + \"&theme.backgroundColor=\" + safebgColour\n        + \"&theme.secondaryBackgroundColor=\" + safebotColour\n        + \"&theme.textColor=\" + safetextColour;\n    \n\/\/ Create the wrapper and hidefooter divs\n    var wrapperDiv = document.createElement('div');\n    wrapperDiv.className = \"wrapper\";\n\n    var hideFooterDiv = document.createElement('div');\n    hideFooterDiv.className = \"hidefooter\";\n\n    \/\/ Create the iframe\n    var chatbotIframe = document.createElement('iframe');\n    chatbotIframe.src = finalUrl; \/\/ Using your existing variable\n\n    \/\/ Add the fallback paragraph inside the iframe\n    var fallbackText = document.createElement('p');\n    fallbackText.textContent = \"Your browser doesn't support iframes\";\n    chatbotIframe.appendChild(fallbackText);\n\n    \/\/ Assemble the pieces: put hidefooter and iframe inside the wrapper\n    wrapperDiv.appendChild(hideFooterDiv);\n    wrapperDiv.appendChild(chatbotIframe);\n    \n    \/\/ Inject the fully assembled wrapper into the Qualtrics container\n    this.getQuestionContainer().appendChild(wrapperDiv);\n\n    \/\/  The Message Listener, saving the content to the hidden text box\n    function messageHandler(event) {\n        if (event.data && event.data.type === 'chat_export') {\n            console.log(\"Saving chat for: \" + qthis.questionId);\n            var chatData = JSON.stringify(event.data.history);\n            \n\t\t\t\/\/ Find the textarea element\n        \tvar textArea = qthis.getQuestionContainer().querySelector('textarea');\n\t\t\t\n\t\t\tif (textArea) {\n            \t\/\/ Set the value directly in the HTML element\n            \ttextArea.value = chatData;\n            \n\t\t\t\t\/\/ Force Qualtrics to recognise the change\n\t\t\t\ttextArea.dispatchEvent(new Event('input', { bubbles: true }));\n\t\t\t\ttextArea.dispatchEvent(new Event('change', { bubbles: true }));\n\n\t\t\t\t\/\/ Backup also use the official Qualtrics API method\n\t\t\t\tqthis.setChoiceValue(1, chatData);\n\t\t\t}\n            \n            \/\/ Clean up listener to prevent interference with other chatbot questions\n            window.removeEventListener(\"message\", messageHandler);\n        }\n    }\n\n    window.addEventListener(\"message\", messageHandler);\n\t\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"&nbsp;<br>","DefaultChoices":false,"DataExportTag":"chatbot2","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID5","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    \n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\/\/ EDIT TO CUSTOMISE CHATBOT\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\n\t\/\/ Define the starting message (e.g., Hello, how can i help you today?)\n\tvar myInitialMsg = \"Hello, how can I help you today?\";\n\t\n    \/\/ Define your custom prompt\n    var mySurveyPrompt = `You are a helpful academic assistant`; \n\n\t\/\/ Define the number of conversational turns\n\tvar maxTurns = 2; \/\/ Change this number to your desired limit\n\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\/\/ DON'T EDIT ANYTHING FROM HERE\n\t\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\t\n\tvar qthis = this;\n    \n    \/\/ Hide ONLY this question's text box. The text box (multiline) is used to save the chat, but we must make it hidden. This targets the textarea specifically within this question's container\n    var inputField = this.getQuestionContainer().querySelector('textarea');\n    if (inputField) {\n        inputField.style.display = 'none';\n    }\n\t\n\t\/\/ To edit the provider, model, and app url, configure myProvider, myModel, and appURL as Embedded variables within survey flow. Make sure these appear at the very top of the survey flow.  \n    var myProvider = Qualtrics.SurveyEngine.getEmbeddedData('myProvider');\n    var myModel = Qualtrics.SurveyEngine.getEmbeddedData('myModel');\n\tvar baseUrl = Qualtrics.SurveyEngine.getEmbeddedData('appURL');\t\n\n\tvar userIcon = Qualtrics.SurveyEngine.getEmbeddedData('user_icon');\n\tvar botIcon = Qualtrics.SurveyEngine.getEmbeddedData('bot_icon');\t\n\t\n    \/\/ Custom Colors (Use Hex codes)\n    var bgColour = Qualtrics.SurveyEngine.getEmbeddedData('bgColour');\t; \/\/ Changes the main app background\n    var userColour = Qualtrics.SurveyEngine.getEmbeddedData('userColour'); \/\/ Changes the user's chat bubble and accents\n    var botColour = Qualtrics.SurveyEngine.getEmbeddedData('botColour');; \/\/ Changes the bot's chat bubble and input box\n    var textColour = Qualtrics.SurveyEngine.getEmbeddedData('textColour'); \/\/ Changes the main text color\n\n    \/\/ Encode the colors so the '#' symbol does not break the URL\n    var safebgColour = encodeURIComponent(bgColour);\n\tvar safeuserColour = encodeURIComponent(userColour);\n    var safebotColour = encodeURIComponent(botColour);\n    var safetextColour = encodeURIComponent(textColour);\t\n\t\n\t\/\/ Encode the variables so the ' ' do not break the URL\n\tvar safePrompt = encodeURIComponent(mySurveyPrompt);\n\tvar safeInitialMsg = encodeURIComponent(myInitialMsg);\n\tvar safeUserIcon  = encodeURIComponent(userIcon);\n\tvar safeBotIcon = encodeURIComponent(botIcon);\n\t\n\t\/\/ Build the final URL with all the URL variables\n    var finalUrl = baseUrl + \"?embed=true\" \n        + \"&prompt=\" + safePrompt \n        + \"&provider=\" + myProvider \n        + \"&model=\" + myModel \n        + \"&initial_msg=\" + safeInitialMsg \n        + \"&max_turns=\" + maxTurns \n        + \"&user_icon=\" + safeUserIcon \n        + \"&bot_icon=\" + safeBotIcon\n        + \"&theme.primaryColor=\" + safeuserColour\n        + \"&theme.backgroundColor=\" + safebgColour\n        + \"&theme.secondaryBackgroundColor=\" + safebotColour\n        + \"&theme.textColor=\" + safetextColour;\n    \n\/\/ Create the wrapper and hidefooter divs\n    var wrapperDiv = document.createElement('div');\n    wrapperDiv.className = \"wrapper\";\n\n    var hideFooterDiv = document.createElement('div');\n    hideFooterDiv.className = \"hidefooter\";\n\n    \/\/ Create the iframe\n    var chatbotIframe = document.createElement('iframe');\n    chatbotIframe.src = finalUrl; \/\/ Using your existing variable\n\n    \/\/ Add the fallback paragraph inside the iframe\n    var fallbackText = document.createElement('p');\n    fallbackText.textContent = \"Your browser doesn't support iframes\";\n    chatbotIframe.appendChild(fallbackText);\n\n    \/\/ Assemble the pieces: put hidefooter and iframe inside the wrapper\n    wrapperDiv.appendChild(hideFooterDiv);\n    wrapperDiv.appendChild(chatbotIframe);\n    \n    \/\/ Inject the fully assembled wrapper into the Qualtrics container\n    this.getQuestionContainer().appendChild(wrapperDiv);\n\n    \/\/  The Message Listener, saving the content to the hidden text box\n    function messageHandler(event) {\n        if (event.data && event.data.type === 'chat_export') {\n            console.log(\"Saving chat for: \" + qthis.questionId);\n            var chatData = JSON.stringify(event.data.history);\n            \n\t\t\t\/\/ Find the textarea element\n        \tvar textArea = qthis.getQuestionContainer().querySelector('textarea');\n\t\t\t\n\t\t\tif (textArea) {\n            \t\/\/ Set the value directly in the HTML element\n            \ttextArea.value = chatData;\n            \n\t\t\t\t\/\/ Force Qualtrics to recognise the change\n\t\t\t\ttextArea.dispatchEvent(new Event('input', { bubbles: true }));\n\t\t\t\ttextArea.dispatchEvent(new Event('change', { bubbles: true }));\n\n\t\t\t\t\/\/ Backup also use the official Qualtrics API method\n\t\t\t\tqthis.setChoiceValue(1, chatData);\n\t\t\t}\n            \n            \/\/ Clean up listener to prevent interference with other chatbot questions\n            window.removeEventListener(\"message\", messageHandler);\n        }\n    }\n\n    window.addEventListener(\"message\", messageHandler);\n\t\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\t\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0iGdi8PYxzHyB2m","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}